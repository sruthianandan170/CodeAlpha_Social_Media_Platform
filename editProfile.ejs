<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Edit Profile</title>

<link rel="stylesheet" href="/css/style.css">

</head>


<body>


<!-- Navigation Bar -->

<nav class="navbar">

<div class="logo">

🐦 TwinBirds

</div>

<div class="menu">

<a href="/home">Home</a>

<a href="/feed">Feed</a>

<a href="/profile">Profile</a>

<a href="/my-posts">My Posts</a>

<a href="/logout">Logout</a>

</div>

</nav>



<div class="container">


<div class="profile-card">


<h1>Edit Profile</h1>



<!-- Current Profile Image -->

<div class="avatar">

    <div class="default-avatar">
        👩🏻
    </div>

</div>

  



<form 
action="/edit-profile" 
method="POST" 
enctype="multipart/form-data">



<label>
Name
</label>


<input

type="text"

name="name"

value="<%= user.name %>"

required

>



<br><br>



<label>
Email
</label>


<input

type="email"

value="<%= user.email %>"

readonly

>



<br><br>




<label>
Bio
</label>


<textarea

name="bio"

rows="4"

placeholder="Write something about yourself"

><%= user.bio %></textarea>



<br><br>




<div class="avatar-container">

    <% if(user.profileImage){ %>

        <img
        src="<%= user.profileImage %>"
        class="profile-img">

    <% } else { %>

        <div class="default-avatar">
            👩
        </div>

    <% } %>

</div>



<br><br>



<button type="submit">

Update Profile

</button>



</form>



</div>


</div>



<footer>

© 2026 CodeAlpha Social Media Platform

</footer>



</body>

</html>